# NPC Dialogue Engine — environment configuration
# Copy to `.env` and adjust as needed. All values shown are defaults.

# ─── Model selection ─────────────────────────────────────────────
# auto         — use real transformers if torch is installed, else mock
# mock         — always use the deterministic MockDialogueModel (CPU, no GPU)
# transformers — force the real Qwen + LoRA pipeline (requires torch + GPU recommended)
DIALOGUE_MODEL_MODE=auto

# ─── LLM (MODEL_*) ───────────────────────────────────────────────
MODEL_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
# MODEL_LORA_PATH=models/lora/final
MODEL_LOAD_IN_4BIT=true
MODEL_MAX_NEW_TOKENS=256
MODEL_TEMPERATURE=0.7
MODEL_TOP_P=0.9
MODEL_REPETITION_PENALTY=1.1
MODEL_DEVICE=auto

# ─── RAG (RAG_*) ─────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_COLLECTION_NAME=game_lore
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=3
RAG_RELEVANCE_THRESHOLD=0.35
# RAG_CHROMA_PERSIST_DIR=./chroma_data
# RAG_LORE_DIR=./data/lore

# ─── API (API_*) ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_MAX_SESSION_HISTORY=10
API_SESSION_TTL_SECONDS=3600

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | console

# ─── Optional: Hugging Face / experiment tracking ────────────────
# HF_TOKEN=hf_...
# WANDB_API_KEY=...
# WANDB_PROJECT=npc-dialogue-engine
